# KnK Inn — Apache / LiteSpeed config
#
# Diagnosis state (2026-04-28):
#   robots.txt is correct and live, yet Facebook's debugger reports
#   HTTP 403 from facebookexternalhit. That's a server-level WAF /
#   mod_security 403 — happening BEFORE robots.txt is read. FB's
#   "could be a robots.txt block" error is misleading.
#
# Goal: convince Matbao's mod_security and any other UA-blocking
# layer to let social-preview scrapers through. We try several
# approaches because LiteSpeed shared hosting often partially
# honours .htaccess directives — best to cover all the bases.

# ------------------------------------------------------------------
# 1. Tag known social scrapers via SetEnvIfNoCase. This is
#    universally supported (Apache 2.2+, LiteSpeed) and gives us
#    an env var we can use in subsequent rules.
# ------------------------------------------------------------------
SetEnvIfNoCase User-Agent "facebookexternalhit"      KNK_SOCIAL_BOT=1
SetEnvIfNoCase User-Agent "facebookcatalog"          KNK_SOCIAL_BOT=1
SetEnvIfNoCase User-Agent "Facebot"                  KNK_SOCIAL_BOT=1
SetEnvIfNoCase User-Agent "Twitterbot"               KNK_SOCIAL_BOT=1
SetEnvIfNoCase User-Agent "LinkedInBot"              KNK_SOCIAL_BOT=1
SetEnvIfNoCase User-Agent "WhatsApp"                 KNK_SOCIAL_BOT=1
SetEnvIfNoCase User-Agent "TelegramBot"              KNK_SOCIAL_BOT=1
SetEnvIfNoCase User-Agent "Slackbot"                 KNK_SOCIAL_BOT=1
SetEnvIfNoCase User-Agent "Discordbot"               KNK_SOCIAL_BOT=1
SetEnvIfNoCase User-Agent "Pinterestbot"             KNK_SOCIAL_BOT=1

# ------------------------------------------------------------------
# 2. mod_security 2.x — the standard rule pattern that disables
#    the whole rule engine for matching User-Agents. Phase:1 fires
#    before request body parsing, so it's the earliest possible
#    intervention. id 1000 is our private namespace.
# ------------------------------------------------------------------
<IfModule mod_security2.c>
    SecRule REQUEST_HEADERS:User-Agent "@rx (?i)(facebookexternalhit|facebookcatalog|facebot|twitterbot|linkedinbot|whatsapp|telegrambot|slackbot|discordbot|pinterestbot)" \
        "id:1000,phase:1,nolog,allow,ctl:ruleEngine=Off,ctl:auditEngine=Off"
</IfModule>

# Some Matbao installs use the older mod_security (1.x / unversioned).
<IfModule mod_security.c>
    SecFilterEngine Off
</IfModule>

# ------------------------------------------------------------------
# 3. Visible proof header — when a social bot fetches the page,
#    they (and we) get back X-KnK-Bot-Pass: yes. If the response
#    still has no such header in the FB debugger's "Server Response"
#    view, this .htaccess never ran and the issue is upstream of
#    Apache / LiteSpeed (CDN, account-level WAF, Matbao support
#    ticket territory).
# ------------------------------------------------------------------
<IfModule mod_headers.c>
    Header always set X-KnK-Bot-Pass "yes" env=KNK_SOCIAL_BOT
</IfModule>

# ------------------------------------------------------------------
# 4. CORS for static images — some scrapers strict about og:image
#    cross-origin fetches.
# ------------------------------------------------------------------
<FilesMatch "\.(jpg|jpeg|png|gif|webp|svg)$">
    <IfModule mod_headers.c>
        Header set Access-Control-Allow-Origin "*"
    </IfModule>
</FilesMatch>

# ------------------------------------------------------------------
# 5. Static asset cache — unrelated to bots, but nice to have while
#    we're touching the docroot config.
# ------------------------------------------------------------------
<FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico|css|js|woff2)$">
    <IfModule mod_expires.c>
        ExpiresActive On
        ExpiresDefault "access plus 7 days"
    </IfModule>
</FilesMatch>
